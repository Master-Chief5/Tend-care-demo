# Without it, the coach tab still works using built-in canned cues.
# Local dev: copy to `.env` (Vite/Vercel load it) or `export ANTHROPIC_API_KEY=...`
# Vercel: set this as a Project Environment Variable.
ANTHROPIC_API_KEY=sk-ant-...
